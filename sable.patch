+  display:flex;align-items:center;justify-content:center;flex-shrink:0}
+#rootResults .ent .eic svg{width:15px;height:15px;color:var(--accent)}
+#rootResults .ent .eic.tag{font-family:var(--mono);font-weight:600;font-size:15px}
+#rootResults .ent .enm{flex:1;min-width:0;font-size:14.5px;font-weight:500;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
+#rootResults .ent .enm mark{background:var(--accent-soft);color:var(--accent);border-radius:3px;padding:0 1px}
+:root[data-theme="dark"] #rootResults .ent .enm mark{background:rgba(216,162,90,.22)}
+#rootResults .ent .ecnt{font-family:var(--mono);font-size:11.5px;color:var(--text-3);flex-shrink:0}
+#rootResults .ent .echev{width:15px;height:15px;color:var(--text-3);flex-shrink:0}
+#rootResults .smore{width:100%;background:var(--surface-2);border:1px solid var(--border-2);color:var(--text-2);
+  font-family:inherit;font-size:13px;font-weight:500;padding:9px;border-radius:10px;cursor:pointer;margin-top:1px}
+#rootResults .smore:hover{color:var(--text);border-color:var(--text-3)}
+
+/* ── v2.16 — sélection : en-tête stable + case en gouttière ───────── */
+/* En-tête : la barre de sélection recouvre le fil d'Ariane (même hauteur) et
+   la recherche reste en place → aucun décalage vertical à l'entrée en sélection. */
+.pilehead{position:relative}
+.selbar{position:absolute;inset:0;display:none;align-items:center;gap:8px}
+body.selecting .pilehead .crumb{visibility:hidden}
+body.selecting #pileSelbar{display:flex}
+.selbar .seln{font-size:16px;font-weight:600;flex:1}
+.selbar .sellnk{background:none;border:none;color:var(--accent);font-family:inherit;font-size:14px;font-weight:500;cursor:pointer;padding:8px 6px}
+
+/* Case à cocher : réserve sa place à gauche, jamais par-dessus le contenu (liste & grandes cartes) */
+.selwrap{display:flex;align-items:center;gap:12px;margin-bottom:8px}
+.selwrap>[data-id]{flex:1;min-width:0;margin-bottom:0}
+.rcheck{width:24px;height:24px;border-radius:50%;border:2px solid var(--border-2);background:var(--surface);
+  display:flex;align-items:center;justify-content:center;color:transparent;flex-shrink:0;transition:.12s}
+.rcheck svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:3;stroke-linecap:round;stroke-linejoin:round}
+.rcheck.on{background:var(--accent);border-color:var(--accent);color:var(--accent-ink)}
+#pileList [data-id].sel{border-color:var(--accent);box-shadow:0 0 0 1px var(--accent)}
+/* Galerie : pas de gouttière possible dans la grille → pastille opaque en coin */
+.gcard.selgrid{position:relative}
+.gcard.selgrid .rcheck{position:absolute;top:8px;left:8px;box-shadow:var(--sh-card);z-index:3}
+
+/* Barre d'action par lot (bas) */
+body.selecting .tabs{display:none}
+.batchbar{position:fixed;left:0;right:0;bottom:0;z-index:30;display:none;gap:10px;max-width:540px;margin:0 auto;
+  padding:12px 18px calc(14px + env(safe-area-inset-bottom));background:linear-gradient(to top,var(--bg) 68%,transparent)}
+body.selecting.hasSel .batchbar{display:flex}
+.batchbar .batchbtn{flex:1;font-family:inherit;font-size:14px;font-weight:600;padding:13px;border-radius:12px;cursor:pointer;
+  display:flex;align-items:center;justify-content:center;gap:8px;border:1px solid var(--border-2);background:var(--surface);color:var(--text);box-shadow:var(--sh-card);transition:.13s}
+.batchbar .batchbtn:hover{border-color:var(--accent)}
+.batchbar .batchbtn.primary{background:var(--accent);border-color:var(--accent);color:var(--accent-ink)}
+.batchbar .batchbtn .ic{width:16px;height:16px}
+.batchbar .batchbtn .taghash{font-family:var(--mono);font-weight:600}
+
+/* Coup de pouce « même source » */
+.srcnudge{display:flex;align-items:center;gap:12px;width:100%;background:var(--accent-soft);border:1px solid transparent;
+  border-radius:12px;padding:12px 14px;margin:0 0 12px;cursor:pointer;text-align:left;font-family:inherit}
+.srcnudge .sn-ic{width:32px;height:32px;border-radius:9px;background:rgba(174,113,39,.16);color:var(--accent);
+  display:flex;align-items:center;justify-content:center;flex-shrink:0}
+.srcnudge .sn-ic .ic{width:16px;height:16px}
+.srcnudge .sn-tx{flex:1;min-width:0}
+.srcnudge .sn-tx b{display:block;color:var(--text);font-size:14px;font-weight:600}
+.srcnudge .sn-tx span{font-size:12.5px;color:var(--accent)}
+.srcnudge .sn-go{font-family:var(--mono);color:var(--accent);flex-shrink:0}
+
+/* v2.17 — barre d'outils de la pile en icônes seules (moins encombrée) */
+.crumb .pill{width:40px;height:40px;padding:0;gap:0;justify-content:center}
+.crumb .pill svg{width:17px;height:17px}
