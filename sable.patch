 a.srow{text-decoration:none}
+
+/* ── v2.13 — recherche unifiée : résultats groupés + barre figée ───── */
+#tab-categories .search{position:sticky;top:0;z-index:5;background:var(--bg);padding-top:6px}
+#tab-categories .search::before{content:"";position:absolute;left:-18px;right:-18px;top:0;bottom:0;background:var(--bg);z-index:-1}
+#rootResults .sec{margin-top:16px}
+#rootResults .sec:first-child{margin-top:2px}
+#rootResults .sechead{display:flex;align-items:baseline;justify-content:space-between;margin:0 2px 8px}
+#rootResults .sechead .lbl{font-family:var(--mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;color:var(--text-3)}
+#rootResults .sechead .n{font-family:var(--mono);font-size:11px;color:var(--text-3)}
+#rootResults .ent{display:flex;align-items:center;gap:11px;width:100%;background:var(--surface);border:1px solid var(--border);
+  border-radius:11px;padding:10px 13px;margin-bottom:7px;cursor:pointer;text-align:left;font-family:inherit;transition:.13s}
